# Commonplace — environment
# Copy to .env and fill in your values

# Admin user (created on first run)
COMMONPLACE_USERNAME=admin
COMMONPLACE_PASSWORD=change-me-to-something-secret

# Session secret (auto-generated if not set; changing it logs everyone out)
SESSION_SECRET=

# Database URL (default: sqlite:////app/data/commonplace.db)
# DATABASE_URL=sqlite+aiosqlite:////app/data/commonplace.db

# Hardcover API key (for more accurate book covers)
# Get yours at https://hardcover.app/account/api
# HARDCOVER_API_KEY=your-key-here

# Bookcover API URL (self-hosted Goodreads cover scraper)
# Default: https://bookcover.longitood.com
# Set to your self-hosted instance if you run one
# BOOKCOVER_API_URL=http://192.168.1.130:8080
