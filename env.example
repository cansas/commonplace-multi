# Commonplace — environment
# Copy to .env and fill in your values

# Admin user (created on first run)
COMMONPLACE_USERNAME=admin
COMMONPLACE_PASSWORD=change-me-to-something-secret

# Session secret (auto-generated if not set; changing it logs everyone out)
SESSION_SECRET=

# Session cookie HTTPS-only (default: true; set to false for local dev without TLS)
SESSION_HTTPS_ONLY=true

# Database URL (default: sqlite:////app/data/commonplace.db)
# DATABASE_URL=sqlite+aiosqlite:////app/data/commonplace.db

# Hardcover API key (fallback for book covers when Open Library has no result)
# Get yours at https://hardcover.app/account/api (free tier available)
# HARDCOVER_API_KEY=your-key-here

# Digest trigger secret — set to require a matching x-digest-secret header
# on POST /api/digest/trigger (for external cron). Empty = no auth.
# DIGEST_SECRET=

# Set to "1" to disable the built-in poller (use /api/digest/trigger from cron)
# DISABLE_DIGEST_SCHEDULER=1

# Web Push VAPID keys (auto-generated if not set; persisted to data/.vapid_keys)
# The public key must be base64url-encoded raw 65-byte uncompressed EC point.
# Generate with: python3 -c "
# from pywebpush import Vapid
# from cryptography.hazmat.primitives import serialization
# from base64 import urlsafe_b64encode
# v = Vapid(); v.generate_keys()
# pub = urlsafe_b64encode(v.public_key.public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)).decode().rstrip('=')
# priv = v.private_key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption()).decode().strip()
# print(f'VAPID_PUBLIC_KEY={pub}'); print(f'VAPID_PRIVATE_KEY={priv}')
# "
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIM_EMAIL=mailto:admin@yourdomain.com

